# SpecialCoffee AI — Variables de entorno requeridas
# Copiar a .env y rellenar los valores reales ANTES de levantar el backend.
# NUNCA commitear .env con valores reales.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Usuario con privilegios para crear tablas y roles
POSTGRES_USER=postgres
# Contraseña del usuario PostgreSQL (cambiar en producción)
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
# Nombre de la base de datos
POSTGRES_DB=specialcoffee
# Host de PostgreSQL visto desde Docker
# Windows: host.docker.internal | Linux: localhost | Docker Compose: nombre del servicio
DB_HOST=host.docker.internal

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret para firmar tokens JWT. Debe ser idéntico en auth y PostgREST.
# Generar con: openssl rand -base64 48
JWT_SECRET=CAMBIAR_POR_SECRET_ALEATORIO_DE_48_BYTES

# ── Auth service (FastAPI) ────────────────────────────────────────────────────
# Algoritmo de firma JWT (no cambiar salvo requerimiento explícito)
JWT_ALGORITHM=HS256
# Minutos de validez del access token
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Días de validez del refresh token
REFRESH_TOKEN_EXPIRE_DAYS=30
# Puerto en que escucha el auth service
AUTH_PORT=8000
